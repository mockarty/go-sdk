{
  "consumer": {"name": "OrderService"},
  "provider": {"name": "PaymentService"},
  "interactions": [
    {
      "description": "a charge request",
      "providerState": "payment service is up",
      "request": {
        "method": "POST",
        "path": "/charge",
        "headers": {"Content-Type": "application/json"},
        "body": {"amount": 100},
        "matchingRules": {
          "$.body.amount": {"matchers": [{"match": "type"}]}
        }
      },
      "response": {
        "status": 200,
        "headers": {"Content-Type": "application/json"},
        "body": {"id": "abc"},
        "matchingRules": {
          "$.body.id": {"matchers": [{"match": "type"}]}
        }
      }
    }
  ],
  "metadata": {
    "pactSpecification": {"version": "3.0.0"}
  }
}
